USE_MYSQL=1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=hotel_bot
MYSQL_USER=hotel_bot
MYSQL_PASSWORD=cambia_esta_contrasena

# Opcional si usas socket local en vez de host/puerto:
# MYSQL_SOCKET=/var/run/mysqld/mysqld.sock

# Opcional si el binario no se llama "mysql":
# MYSQL_CLI=/usr/bin/mysql
